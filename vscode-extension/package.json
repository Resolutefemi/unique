{
  "name": "unique",
  "displayName": "Unique.js",
  "description": "Support for .jsk and .tsk Unique.js files. Syntax highlighting, snippets, and the Unique.js logo.",
  "version": "1.0.0",
  "publisher": "Resolutefemi",
  "icon": "images/logo.png",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Programming Languages", "Snippets"],
  "keywords": ["unique", "jsk", "tsk", "web", "framework", "rust"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Resolutefemi/unique"
  },
  "contributes": {
    "languages": [
      {
        "id": "unique-js",
        "aliases": ["Unique JS", "jsk"],
        "extensions": [".jsk"],
        "icon": {
          "light": "images/logo-light.svg",
          "dark": "images/logo-dark.svg"
        },
        "configuration": "./language-configuration.json"
      },
      {
        "id": "unique-ts",
        "aliases": ["Unique TS", "tsk"],
        "extensions": [".tsk"],
        "icon": {
          "light": "images/logo-light.svg",
          "dark": "images/logo-dark.svg"
        },
        "configuration": "./language-configuration.json"
      },
      {
        "id": "unique-page",
        "aliases": ["Unique Page", "kng"],
        "extensions": [".kng", ".jsk", ".tsk"],
        "icon": {
          "light": "images/logo-light.svg",
          "dark": "images/logo-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "unique-js",
        "scopeName": "source.kng-js",
        "path": "./syntaxes/unique-js.tmLanguage.json"
      },
      {
        "language": "unique-ts",
        "scopeName": "source.kng-ts",
        "path": "./syntaxes/unique-ts.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "unique-js",
        "path": "./snippets/unique.json"
      },
      {
        "language": "unique-ts",
        "path": "./snippets/unique.json"
      }
    ],
    "icons": {
      "unique-logo": {
        "description": "Unique.js logo",
        "default": {
          "fontPath": "images/logo.svg",
          "fontCharacter": "🥋"
        }
      }
    }
  }
}
