{
  "Kungfu GET route": {
    "prefix": "kget",
    "body": [
      "app.get('${1:/path}', (req) => {",
      "  return { status: ${2:200}, body: JSON.stringify(${3:{ message: '${4:hello}' }}) };",
      "});"
    ],
    "description": "Register a GET route"
  },
  "Kungfu POST route": {
    "prefix": "kpost",
    "body": [
      "app.post('${1:/path}', (req) => {",
      "  const body = JSON.parse(req.body || '{}');",
      "  return { status: ${2:201}, body: JSON.stringify(${3:{ created: true }}) };",
      "});"
    ],
    "description": "Register a POST route"
  },
  "Kungfu App setup": {
    "prefix": "kungfu",
    "body": [
      "const { Kungfu } = require('kungfu');",
      "",
      "const app = new Kungfu();",
      "",
      "app.get('${1:/hello}', (req) => {",
      "  return { status: 200, body: JSON.stringify({ message: '${2:world}' }) };",
      "});",
      "",
      "app.listen(${3:3000});"
    ],
    "description": "Complete Kungfu.js app setup"
  },
  "Kungfu async route": {
    "prefix": "kasync",
    "body": [
      "app.get('${1:/path}', async (req) => {",
      "  const data = await fetchData();",
      "  return { status: 200, body: JSON.stringify(data) };",
      "});"
    ],
    "description": "Async route handler"
  },
  "Kungfu CSS import": {
    "prefix": "kcss",
    "body": [
      "const { compileCss } = require('kungfu');",
      "const css = compileCss('${1:flex p-4 text-red-500}');"
    ],
    "description": "Compile CSS utility classes"
  }
}
