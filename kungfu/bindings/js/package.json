{
  "name": "@kungfu/core",
  "version": "1.0.0",
  "description": "One API surface, infinite languages. A polyglot web framework with a Rust core.",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "kungfu",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "node -e \"const k=require('./kungfu.linux-x64-gnu.node'); console.log('Version:', k.version())\""
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">= 18"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Resolutefemi/kungfu.git",
    "directory": "bindings/js"
  },
  "keywords": [
    "web",
    "framework",
    "rust",
    "napi",
    "polyglot",
    "http",
    "server",
    "fast"
  ]
}
