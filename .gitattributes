# Linguist language detection overrides.
# Tells GitHub's language stats to correctly identify Rust as the primary language.

# All .rs files are Rust.
*.rs linguist-language=Rust

# Generated/binding files — excluded from language stats.
bindings/js/index.js linguist-generated=true
bindings/js/index.d.ts linguist-generated=true
bindings/js/examples/*.js linguist-generated=true
bindings/js/examples/*.ts linguist-generated=true
bindings/python/python/** linguist-generated=true
bindings/python/examples/*.py linguist-generated=true
bindings/go/examples/** linguist-generated=true
frontend/src/hydration.js linguist-generated=true

# Cargo.lock is generated.
Cargo.lock linguist-generated=true

# kungfu.h is generated by cbindgen.
core/kungfu.h linguist-generated=true
