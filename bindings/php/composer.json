{
    "name": "unique/unique",
    "description": "PHP binding for the Unique.js polyglot web framework — Rust core, polyglot bindings. Uses PHP FFI to call libunique_core.",
    "type": "library",
    "license": "MIT OR Apache-2.0",
    "version": "1.0.0",
    "keywords": ["web", "framework", "http", "server", "rust", "ffi", "polyglot"],
    "homepage": "https://unique.js.org",
    "authors": [
        {
            "name": "Unique.js Contributors",
            "email": "noreply@unique.js.org",
            "homepage": "https://unique.js.org"
        }
    ],
    "support": {
        "issues": "https://github.com/Resolutefemi/unique/issues",
        "source": "https://github.com/Resolutefemi/unique/tree/main/bindings/php"
    },
    "require": {
        "php": ">=8.0",
        "ext-ffi": "*"
    },
    "autoload": {
        "psr-4": {
            "Unique\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}
